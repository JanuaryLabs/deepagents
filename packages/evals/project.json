{
  "name": "@deepagents/evals",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/evals/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "additionalEntryPoints": [
          "packages/evals/src/engine/index.ts",
          "packages/evals/src/scorers/index.ts",
          "packages/evals/src/store/index.ts",
          "packages/evals/src/dataset/index.ts",
          "packages/evals/src/comparison/index.ts",
          "packages/evals/src/reporters/index.ts",
          "packages/evals/src/evaluate/index.ts"
        ]
      }
    },
    "test": {
      "options": {
        "command": "node --test --no-warnings --test-force-exit --test-reporter=spec --test-reporter=junit --test-reporter-destination=stdout --test-reporter-destination=../../test-results/evals.xml"
      }
    }
  }
}
