{
  "name": "@deepagents/text2sql",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/text2sql/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build-lib", "build-cli"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "true"
      }
    },
    "build-lib": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "additionalEntryPoints": [
          "packages/text2sql/src/lib/adapters/groundings/index.ts",
          "packages/text2sql/src/lib/adapters/sqlite/index.ts",
          "packages/text2sql/src/lib/adapters/postgres/index.ts",
          "packages/text2sql/src/lib/adapters/mysql/index.ts",
          "packages/text2sql/src/lib/adapters/bigquery/index.ts",
          "packages/text2sql/src/lib/adapters/sqlserver/index.ts",
          "packages/text2sql/src/lib/adapters/spreadsheet/index.ts",
          "packages/text2sql/src/lib/synthesis/index.ts"
        ]
      }
    },
    "build-cli": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["build-lib"],
      "options": {
        "main": "packages/text2sql/src/bin/sql.ts",
        "outputPath": "{projectRoot}/dist/bin",
        "declaration": false,
        "skipTypeCheck": true,
        "sourcemap": false,
        "thirdParty": false,
        "format": ["esm"],
        "esbuildOptions": {
          "packages": "external"
        }
      }
    },
    "test": {
      "options": {
        "command": "node --test --no-warnings --test-force-exit --test-reporter=spec --test-reporter=junit --test-reporter-destination=stdout --test-reporter-destination=../../test-results/text2sql.xml"
      }
    },
    "eval": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node --no-warnings",
        "cwd": "{projectRoot}/src/evals",
        "envFile": ".env"
      }
    }
  }
}
