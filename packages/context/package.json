{
  "name": "@deepagents/context",
  "version": "3.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JanuaryLabs/deepagents",
    "directory": "packages/context"
  },
  "bugs": {
    "url": "https://github.com/JanuaryLabs/deepagents/issues"
  },
  "homepage": "https://github.com/JanuaryLabs/deepagents#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./tracing": {
      "types": "./dist/lib/tracing/index.d.ts",
      "import": "./dist/lib/tracing/index.js",
      "default": "./dist/lib/tracing/index.js"
    },
    "./sandbox/strace": {
      "types": "./dist/lib/sandbox/strace/index.d.ts",
      "import": "./dist/lib/sandbox/strace/index.js",
      "default": "./dist/lib/sandbox/strace/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "!**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.36",
    "@ai-sdk/provider": "^3.0.10",
    "@deepagents/agent": "3.1.0",
    "ai": "^6.0.174",
    "bash-tool": "^1.3.16",
    "chalk": "^5.6.0",
    "dedent": "^1.7.0",
    "gpt-tokenizer": "^3.4.0",
    "just-bash": "^3.0.1",
    "nano-spawn": "^2.0.0",
    "pluralize": "^8.0.0",
    "stringcase": "^4.3.1",
    "tiny-tfidf": "^1.0.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.76 || ^4.0.0"
  },
  "devDependencies": {
    "@daytona/sdk": "^0.175.0",
    "@types/debug": "^4.1.12",
    "@types/mssql": "^12.3.0",
    "@types/pg": "^8.20.0",
    "nock": "^14.0.14",
    "pg-boss": "^12.18.2"
  },
  "peerDependencies": {
    "@daytona/sdk": "^0.175.0",
    "@rivet-dev/agent-os-common": "^0.0.260331072558",
    "@rivet-dev/agent-os-core": ">=0.1.0",
    "mssql": "^12.5.2",
    "pg": "^8.20.0"
  },
  "peerDependenciesMeta": {
    "@daytona/sdk": {
      "optional": true
    },
    "mssql": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "@rivet-dev/agent-os-core": {
      "optional": true
    },
    "@rivet-dev/agent-os-common": {
      "optional": true
    }
  }
}
